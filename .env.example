# ─── Base de datos (Supabase PostgreSQL) ─────────────────────────────────────
# Obtener en: supabase.com → tu proyecto → Settings → Database → Connection string
#
# DATABASE_URL → usar el "Transaction pooler" (puerto 6543) → reemplazá [YOUR-PASSWORD]
# DIRECT_URL   → usar el "Direct connection" (puerto 5432)  → reemplazá [YOUR-PASSWORD]
#
# En Supabase: Settings → Database → Connection string → URI
DATABASE_URL="postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ─── Auth (NextAuth) ──────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 32
AUTH_SECRET="tu-secret-muy-largo-aqui"
NEXTAUTH_URL="http://localhost:3000"

# Credenciales de acceso al dashboard (solo Fede)
ADMIN_EMAIL="fede@fmcode.com"
ADMIN_PASSWORD="tu-password-seguro"

# ─── Anthropic (Claude API) ───────────────────────────────────────────────────
# Obtener en: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Instagram Graph API ──────────────────────────────────────────────────────
# Obtener en: https://developers.facebook.com → crear app → Instagram Basic Display
INSTAGRAM_APP_ID="tu-app-id"
INSTAGRAM_APP_SECRET="tu-app-secret"

# ─── Cloudinary (storage de imágenes) ────────────────────────────────────────
# Obtener en: https://cloudinary.com → free tier → Dashboard
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="tu-api-key"
CLOUDINARY_API_SECRET="tu-api-secret"

# ─── URLs ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Vercel Cron (solo en producción) ────────────────────────────────────────
# Generar con: openssl rand -base64 32
CRON_SECRET="otro-secret-largo-aqui"
